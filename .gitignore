macOS/build/
macOS/build-verify/
.env
.env.build

# Release artifacts — built locally by scripts/build-dmg.sh, distributed via
# GitHub Releases, not via git.
Dicticus.dmg
*.dmg

# GSD planning artifacts — research notes, plan docs, UAT transcripts (which
# include actual user dictation samples). Local-only working files; not for
# public distribution. Untracking ONLY hides these from future commits — see
# git history for previously-published versions.
.planning/*
# Exceptions: GSD state files must be tracked so worktree merges don't drop
# them. Without these, the executor force-adds them with `git add -f` and
# merges break with confusing "deleted in target" diffs (see Wave 2 recovery
# note on 2026-05-17, fixed by cherry-pick + manual sync commits).
# Must use `.planning/*` (not `.planning/`) above — git can't re-include
# files via `!` if their parent directory is excluded.
!.planning/ROADMAP.md
!.planning/STATE.md
!.planning/MILESTONES.md

# macOS Finder metadata
.DS_Store
**/.DS_Store

# Claude Code session state — local-only, includes worktrees + per-machine settings
.claude/

# .remember/ keeps source-of-truth memory files (now.md, today-*.md, recent.md,
# archive.md) but the autonomous save logs are local-only churn. The
# `.remember/.gitignore` already excludes new files, but historical log files
# were already tracked before that gitignore landed; they're being untracked
# in the same commit that adds this rule.
.remember/logs/
.remember/tmp/

# DebugRecorder output — local-only JSONL cleanup traces produced by the
# Dicticus-Debug-Recorder scheme. Recorder code is compiled out of the public
# Release build (no DEBUG_RECORDER flag); the on-disk path lives under
# ~/Library/Application Support, but this guards against a project-relative
# override.
DebugRecordings/
